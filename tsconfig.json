{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": false,
    "skipLibCheck": true,
    "lib": ["ESNext", "DOM", "WebWorker"],
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["index.ts", "src/**/*.ts"]
}
